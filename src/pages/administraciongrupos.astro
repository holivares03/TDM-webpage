---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const allPlayers = [
  { id: 1, name: "Lasseh" },
  { id: 2, name: "Intercambing" },
  { id: 3, name: "siiphs" },
  { id: 4, name: "Mathi" },
  { id: 5, name: "Renscereol" },
  { id: 6, name: "Deruz" },
  { id: 7, name: "sarondres" },
  { id: 8, name: "MonkiDonki" },
  { id: 9, name: "Nixiaa" },
  { id: 10, name: "Touche" },
  { id: 11, name: "yoistr" },
  { id: 12, name: "tfge" },
  { id: 13, name: "nekore" },
  { id: 14, name: "Shiny Froakie" },
  { id: 15, name: "Blackmoderm10" },
  { id: 16, name: "rathalina" },
];

const games = [
  "osu!",
  "WarioWare",
  "Smash Bros",
  "Mario Kart",
  "Wii Sports",
  "Move or Die",
  "TETR.IO",
  "Mario Strikers",
  "Cachipún",
  "Chess Blitz",
  "ESPECIAL"
